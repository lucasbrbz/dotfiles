# set super as mod
super + Return
    alacritty

# kill focused window
super + x
    bspc node -c

super + Tab
    bspc desktop -f last.local

# change focus
super + j
    bspc node -f west
super + k
    bspc node -f south
super + i
    bspc node -f north
super + l
    bspc node -f east

# alternatively, you can use the cursor keys:
super + Left
    bspc node -f west
super + Down
    bspc node -f south
super + Up
    bspc node -f north
super + Right
    bspc node -f east

# move focused window
super + shift + j
    bspc node -s west
super + shift + k
    bspc node -s south
super + shift + i
    bspc node -s north
super + shift + l
    bspc node -s east

# alternatively, you can use the cursor keys:
super + shift + Left
    bspc node -s west
super + shift + Down
    bspc node -s south
super + shift + Up
    bspc node -s north
super + shift + Right
    bspc node -s east

# move workspace to other monitor
super + n
    bspc desktop -m next --follow

# split in horizontal orientation
super + h
    bspc node -p west

# split in vertical orientation
super + v
    bspc node -p south

# enter fullscreen mode for the focused container
super + f
    bspc node -t ~fullscreen

# change container layout equivalents
super + t
    bspc desktop -l monocle

super + e
    bspc desktop -l tiled

# cycle windows while in monocle
super + comma
    bspc node -f prev.local.window

super + period
    bspc node -f next.local.window

# toggle tiling / floating
super + shift + space
    bspc node -t ~floating

# focus next/prev between windows
super + space
    bspc node -f next.local.window

# reload the configuration file
super + shift + c
    bspc wm -r

# restart bspwm in place
super + shift + r
    bspc wm -r

# audio / media / brightness
XF86AudioRaiseVolume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
XF86AudioLowerVolume
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
XF86AudioPlay
    playerctl play-pause
XF86AudioPause
    playerctl play-pause
XF86AudioNext
    playerctl next
XF86AudioPrev
    playerctl previous
XF86MonBrightnessUp
    brightnessctl -q set +10%
XF86MonBrightnessDown
    brightnessctl -q set 10%-
XF86Display
    xrandr_display_mode primary
Print
    flameshot gui

# launcher
super + d
    rofi -show drun -theme ~/.config/rofi/theme.rasi

super + BackSpace
    ~/.dotfiles/bspwm/scripts/powermenu.sh

# workspace switching
super + 1
    bspc desktop -f '^1'
super + 2
    bspc desktop -f '^2'
super + 3
    bspc desktop -f '^3'
super + 4
    bspc desktop -f '^4'
super + 5
    bspc desktop -f '^5'
super + 6
    bspc desktop -f '^6'
super + 7
    bspc desktop -f '^7'
super + 8
    bspc desktop -f '^8'
super + 9
    bspc desktop -f '^9'
super + 0
    bspc desktop -f '^10'

# move focused window to workspace and follow
super + shift + 1
    bspc node -d '^1' --follow
super + shift + 2
    bspc node -d '^2' --follow
super + shift + 3
    bspc node -d '^3' --follow
super + shift + 4
    bspc node -d '^4' --follow
super + shift + 5
    bspc node -d '^5' --follow
super + shift + 6
    bspc node -d '^6' --follow
super + shift + 7
    bspc node -d '^7' --follow
super + shift + 8
    bspc node -d '^8' --follow
super + shift + 9
    bspc node -d '^9' --follow
super + shift + 0
    bspc node -d '^10' --follow

# system mode replacement
super + BackSpace ; l
    betterlockscreen -l
super + BackSpace ; shift + s
    systemctl suspend
super + BackSpace ; r
    systemctl reboot
super + BackSpace ; s
    systemctl poweroff -i

# resize mode approximation
super + r ; j
    bspc node -z left -20 0
super + r ; l
    bspc node -z right 20 0
super + r ; i
    bspc node -z top 0 -20
super + r ; k
    bspc node -z bottom 0 20

super + r ; Left
    bspc node -z left -20 0
super + r ; Right
    bspc node -z right 20 0
super + r ; Up
    bspc node -z top 0 -20
super + r ; Down
    bspc node -z bottom 0 20